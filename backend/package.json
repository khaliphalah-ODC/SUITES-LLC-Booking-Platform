{
  "name": "the-suites-backend",
  "version": "1.0.0",
  "description": "Express.js backend for The SUITES hotel booking website.",
  "main": "src/server.js",
  "scripts": {
    "db:migrate": "node scripts/run-sql.js src/db/migrations/001_initial_schema.sql src/db/migrations/002_refresh_tokens.sql src/db/migrations/003_user_status.sql",
    "db:seed": "node scripts/run-sql.js src/db/seeds/001_seed_catalog.sql",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js"
  },
  "keywords": [
    "the-suites",
    "hotel",
    "booking",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pg": "^8.13.1",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
